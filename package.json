{
  "name": "ai-gods-project",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "validate:orchestrator": "node --env-file=.env scripts/validate-orchestrator.mjs",
    "verify:citations": "node --env-file=.env scripts/verify-live-citations.mjs",
    "probe:custom-budget": "node --env-file=.env scripts/probe-custom-budget.mjs",
    "audit:supabase-access": "node --env-file=.env scripts/audit-supabase-access.mjs --out outputs/supabase-access-audit.json",
    "apply-rls": "node --env-file=.env scripts/apply-supabase-rls.mjs",
    "setup:ops-env": "node --env-file=.env scripts/setup-ops-dashboard-env.mjs",
    "check:warehouse": "node --env-file=.env scripts/check-warehouse-status.mjs",
    "check:openreview": "node --env-file=.env scripts/check-openreview-search.mjs",
    "openreview:token": "node --env-file=.env scripts/get-openreview-token.mjs",
    "check:request-guard": "node scripts/check-request-guard.mjs",
    "check:training-readiness": "node --env-file=.env scripts/check-training-readiness.mjs --out outputs/training-readiness.json",
    "prepare:training-data": "node --env-file=.env scripts/prepare-training-datasets.mjs",
    "export-data": "python scripts/export-training-data.py",
    "finetune": "python scripts/finetune-god.py --god all",
    "finetune:god": "python scripts/finetune-god.py --god",
    "update-models": "python scripts/merge-and-register.py --god all",
    "train": "npm run export-data && npm run finetune && npm run update-models",
    "train:dpo": "npm run export-data:dpo && python scripts/train_dpo.py",
    "export-data:dpo": "python scripts/generate_dpo_data.py",
    "train:cloud": "python scripts/run-cloud-training.py --god all",
    "serve:remote-webhook": "python scripts/remote-training-webhook.py",
    "serve:model": "python scripts/god-server.py",
    "train:remote-trigger": "node --env-file=.env scripts/trigger-remote-training.mjs",
    "promote:model": "node --env-file=.env scripts/promote-model-version.mjs",
    "activate:stack": "python scripts/activate-serving-stack.py",
    "warehouse:activate": "node --env-file=.env scripts/activate-virtual-warehouse.mjs",
    "warehouse:snapshot": "node --env-file=.env scripts/build-training-snapshots.mjs",
    "warehouse:maintain": "node --env-file=.env scripts/archive-prune-debates.mjs --out outputs/warehouse-maintenance.json",
    "sync-obsidian": "node --env-file=.env scripts/sync-obsidian.cjs",
    "watch-obsidian": "node --env-file=.env scripts/watch-obsidian.cjs"
  },
  "dependencies": {
    "@react-three/drei": "^9.114.3",
    "@react-three/fiber": "^8.17.10",
    "@react-three/postprocessing": "^2.16.3",
    "@supabase/supabase-js": "^2.101.1",
    "chokidar": "^5.0.0",
    "docx": "^9.6.1",
    "framer-motion": "^11.11.17",
    "googleapis": "^171.4.0",
    "gray-matter": "^4.0.3",
    "pdf-parse": "^2.4.5",
    "pptxgenjs": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "youtube-transcript": "^1.3.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "pg": "^8.20.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.11"
  }
}
